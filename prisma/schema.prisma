generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Allowed viewers (pre-approved emails)
model AllowedViewer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  company   String?
  addedAt   DateTime @default(now())
  hasViewed Boolean  @default(false)
  viewedAt  DateTime?
  
  // Link to actual viewer data when they view
  viewer    PitchDeckViewer? @relation(fields: [viewerId], references: [id])
  viewerId  String?
  
  @@index([email])
}

// OTP codes for email verification
model OTPCode {
  id        String   @id @default(cuid())
  email     String
  code      String   // 6-digit code
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([email, code])
}

// Pitch Deck Viewers
model PitchDeckViewer {
  id        String   @id @default(cuid())
  
  // Required fields
  name      String
  email     String   @unique
  
  // Optional fields
  phone     String?
  company   String?
  linkedin  String?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  sessions       PitchDeckSession[]
  allowedViewer  AllowedViewer[]
  
  @@index([email])
  @@index([createdAt])
}

// Each viewing session
model PitchDeckSession {
  id        String   @id @default(cuid())
  viewerId  String
  viewer    PitchDeckViewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  
  // Session metadata
  userAgent String?
  ipAddress String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
  
  // Relations
  slideViews PitchDeckSlideView[]
  
  @@index([viewerId])
  @@index([startedAt])
}

// Individual slide views within a session
model PitchDeckSlideView {
  id          String   @id @default(cuid())
  sessionId   String
  session     PitchDeckSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  slideIndex  Int      // 0-9 for 10 slides
  slideName   String   // "cover", "problem", etc.
  
  // Time tracking
  viewedAt    DateTime @default(now())
  timeSpentMs Int      @default(0) // milliseconds spent on slide
  
  @@index([sessionId])
  @@index([slideIndex])
}

// Access tokens for direct pitch deck access (e.g., investor applications)
model PitchDeckAccessToken {
  id          String    @id @default(cuid())
  token       String    @unique  // e.g., "500global", "ycombinator"
  name        String             // e.g., "500 Global Application"
  description String?            // Optional notes
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?          // Optional expiry
  
  // Analytics
  viewCount   Int       @default(0)
  lastUsedAt  DateTime?
  
  @@index([token])
}

// Early Access / Beta Waitlist
model EarlyAccessRequest {
  id          String    @id @default(cuid())
  
  // Required fields
  name        String
  email       String    @unique
  linkedin    String?   // LinkedIn profile URL
  
  // Optional fields
  company     String?
  role        String?   // founder, product, engineer, designer, other
  useCase     String?   // What they want to build
  
  // Status tracking
  status      String    @default("pending") // pending, approved, rejected, invited
  invitedAt   DateTime?
  
  // Metadata
  source      String?   // Where they came from (utm_source, referral, etc.)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([email])
  @@index([status])
  @@index([createdAt])
}
